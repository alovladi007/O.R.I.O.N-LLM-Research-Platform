# ORION Platform — Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT COMMIT .env. It is in .gitignore (enforced since Session 0.4).
#
# The canonical env loader is src/api/config.py. Strict invariants apply
# whenever ORION_ENV != "development":
#   - CORS_ORIGINS may not be "*"
#   - CORS_ALLOW_METHODS / HEADERS may not contain "*" in any env
#   - JWT_SECRET_KEY must be ≥32 chars (generate: `python -c 'import
#     secrets; print(secrets.token_urlsafe(48))'`)
#   - DATABASE_URL / REDIS_URL may not contain the demo passwords
#     `orion_secure_pwd` / `orion_redis_pwd`

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ORION_ENV=development            # development | staging | production | testing
DEBUG=true
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET_KEY=CHANGE_ME_to_a_real_random_32+_character_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS  (comma-separated; "*" only permitted when ORION_ENV=development)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:8002

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# POSTGRES_* are consumed by docker-compose; DATABASE_URL by the app.
# Keep the password in POSTGRES_PASSWORD and DATABASE_URL in sync.
POSTGRES_USER=orion
POSTGRES_PASSWORD=CHANGE_ME_local_dev_only
POSTGRES_DB=orion_db
DATABASE_URL=postgresql+asyncpg://orion:CHANGE_ME_local_dev_only@localhost:5432/orion_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ---------------------------------------------------------------------------
# Redis (cache + Celery broker)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_local_dev_only
REDIS_URL=redis://:CHANGE_ME_local_dev_only@localhost:6379/0

# ---------------------------------------------------------------------------
# Elasticsearch (optional; comma-separated hosts)
# ---------------------------------------------------------------------------
ELASTICSEARCH_HOSTS=http://localhost:9200

# ---------------------------------------------------------------------------
# MinIO / object storage
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=orion_admin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=orion-data

# ---------------------------------------------------------------------------
# LLM providers (Phase 7 agent)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Materials Project (Phase 1.5 seed data; optional)
# ---------------------------------------------------------------------------
# MP_API_KEY=...

# ---------------------------------------------------------------------------
# Observability (off by default; Phase 10 wires these up)
# ---------------------------------------------------------------------------
# ENABLE_TRACING=false
# JAEGER_HOST=localhost
# JAEGER_PORT=6831
# PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin                 # local-dev default; rotate for prod
# JUPYTER_TOKEN=set_if_you_expose_jupyter

# ---------------------------------------------------------------------------
# Email / alerting (optional)
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASSWORD=CHANGE_ME
# SMTP_FROM=noreply@orion-platform.ai

# ---------------------------------------------------------------------------
# Celery / worker
# ---------------------------------------------------------------------------
# CELERY_BROKER_URL is derived from REDIS_URL by default.
# CELERY_WORKER_CONCURRENCY=4
# CELERY_TASK_TIME_LIMIT=3600

# ---------------------------------------------------------------------------
# Simulation engines (paths on compute cluster, set per-host)
# ---------------------------------------------------------------------------
# QE_EXECUTABLE=/opt/qe/bin/pw.x
# QE_PSEUDO_PATH=/opt/qe/pseudo
# LAMMPS_EXECUTABLE=/opt/lammps/bin/lmp

# ---------------------------------------------------------------------------
# Cloud storage (optional; Phase 13)
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=orion-materials
